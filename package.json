{
  "name": "crystal",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "crystal": "src/cli/index.ts"
  },
  "scripts": {
    "dev": "bun src/cli/index.ts chat",
    "run": "bun src/cli/index.ts run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "ink": "^6.0.0",
    "moment": "^2.30.1",
    "react": "^19.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.0.0",
    "bun-types": "latest",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.58.2",
    "vitepress": "^1.6.4"
  }
}
